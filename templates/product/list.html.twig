{% extends 'base.html.twig' %}

{% block title %}Catalog{% endblock %}

{% block body %}
    <section class="page">
        <div class="hero">
            <div>
                <p class="eyebrow">Legacy promo app</p>
                <h1>Product catalog</h1>
                <p>A tiny catalog and promo code demo that somehow became a team exercise.</p>
            </div>
            {% if app.user %}
                <div class="actions">
                    <a href="{{ path('product_new') }}">Add product</a>
                    <a href="{{ path('admin_promos') }}">Admin promos</a>
                </div>
            {% endif %}
        </div>

        <form method="get" class="search">
            <input type="search" name="q" value="{{ search }}" placeholder="Search by name or SKU">
            <button type="submit">Search</button>
        </form>

        <div class="grid">
            {% for product in products %}
                <article class="card">
                    <div class="card-head">
                        <div>
                            <h2>{{ product.name }}</h2>
                            <p class="muted">{{ product.sku }}</p>
                        </div>
                        <strong>{{ product.displayPrice }}</strong>
                    </div>
                    <p>{{ product.description ?: 'No description yet.' }}</p>
                    <p class="meta">Orders touching this product: {{ product.orders|length }}</p>
                    <p class="meta">Last order email: {{ product.orders|last ? product.orders|last.customerEmail : 'none' }}</p>
                    <div class="actions">
                        {% if app.user %}
                            <a href="{{ path('product_edit', {id: product.id}) }}">Edit</a>
                        {% endif %}
                        <a href="{{ path('checkout_show', {id: product.id}) }}">Checkout</a>
                    </div>
                </article>
            {% else %}
                <p>No products found.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
